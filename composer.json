{
    "name": "bohumer/ai-standards",
    "description": "AI standards and boilerplate for Laravel projects.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bohumer",
            "email": "bohumer.levoslav@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
